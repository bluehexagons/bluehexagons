# Manual deploy: copy to /opt/bx-server/.env and fill in. All values read at startup.
# infra_tools deploy: this file lives in the managed shared dir
#   (/var/www/.infra_tools_shared/<app>/shop-api/.env) and DB_PATH is injected by
#   the unit template — omit DB_PATH there; keep the rest.
LISTEN_ADDR=127.0.0.1:8080
DB_PATH=/opt/bx-server/data/bluehexagons.db
BASE_URL=https://bluehexagons.com
FRONTEND_ORIGIN=https://bluehexagons.com
COOKIE_SECURE=true

# Shop admin and private digital asset storage. Existing primary-admin users are
# granted on startup; new configured admin signups require SHOP_ADMIN_SIGNUP_TOKEN.
SHOP_PRIMARY_ADMIN_EMAIL=loren@bluehexagons.com
SHOP_ADMIN_EMAILS=extra-admin@example.com
# Required only when creating a configured admin account through /shop/admin.html.
# Remove or rotate it after bootstrap.
SHOP_ADMIN_SIGNUP_TOKEN=replace-with-long-random-token
SHOP_UPLOAD_DIR=/opt/bx-server/data/shop_uploads
# Production linked asset URLs must be HTTPS and public. Enable only for local tests.
# SHOP_ALLOW_UNSAFE_ASSET_URLS=true

# Stripe (test keys for staging, live keys for production).
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Insert example products on first boot. Dev/staging only.
# SEED_DEMO=1
