# Manual deploy: copy to /opt/bx-server/.env and fill in. All values read at startup.
# infra_tools deploy: this file lives in the managed shared dir
#   (/var/www/.infra_tools_shared/<app>/shop-api/.env) and DB_PATH is injected by
#   the unit template — omit DB_PATH there; keep the rest.
LISTEN_ADDR=127.0.0.1:8080
DB_PATH=/opt/bx-server/data/bluehexagons.db
BASE_URL=https://api.bluehexagons.com
FRONTEND_ORIGIN=https://bluehexagons.com
COOKIE_SECURE=true

# Stripe (test keys for staging, live keys for production).
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Insert example products on first boot. Dev/staging only.
# SEED_DEMO=1
