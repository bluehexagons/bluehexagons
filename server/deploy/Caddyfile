# Caddy reverse proxy with automatic HTTPS (Let's Encrypt). The API binds to
# loopback; Caddy terminates TLS and forwards same-origin /api requests to it.
bluehexagons.com {
	encode gzip

	# Stripe webhooks post here; everything else is the JSON API.
	handle /api/* {
		reverse_proxy 127.0.0.1:8080
	}

	header {
		# Defense-in-depth response headers (API returns JSON only).
		-Server
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
	}
}
