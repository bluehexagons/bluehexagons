{
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.0.2",
    "glob": "^13.0.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "scripts": {
    "compile": "tsc",
    "watch": "tsc --watch",
    "dev": "vite",
    "host": "vite --host",
    "generate-thumbs": "node scripts/generate-thumbs.ts",
    "build": "tsc && npm run generate-thumbs && vite build",
    "build:shop": "tsc && npm run generate-thumbs && VITE_SHOP=1 vite build",
    "dev:shop": "VITE_SHOP=1 vite",
    "preview": "vite preview"
  }
}
